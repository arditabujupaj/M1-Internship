              for c in range(N_chains)]
    rg_mean = float(np.mean(rg_all))

    e_hist.append(e_val)
    n = len(e_hist); q = max(1, n//4)
    drift = (abs(np.mean(e_hist[-q:]) - np.mean(e_hist[:q]))
             / (abs(np.mean(e_hist[:q])) + 1e-10)) if n >= 4 else 1.0

    print(f"  equil {step+LOG_EVERY:7d} | E={e_val:10.1f} | "
          f"T={T_inst:.1f} K | Rg={rg_mean:.2f} nm | drift={drift:.4f}")

