def coarse_grain(seq_aa, stride):
    beads = []
    for start in range(0, len(seq_aa), stride):
        win  = seq_aa[start : start + stride]
        m    = np.array([MASS_AA[aa]     for aa in win])
        s    = np.array([SIGMA_AA[aa]    for aa in win])
        lam  = np.array([LAMBDA_URRY[aa] for aa in win])
        q    = np.array([CHARGE_AA[aa]   for aa in win])
        beads.append({
            'mass'  : float(m.sum()),
            'sigma' : float((s**3).sum() ** (1/3)),   # volume-additive
            'lam'   : float((m * lam).sum() / m.sum()),# mass-weighted avg
            'charge': float(q.sum()),                  # algebraic sum
        })
    return beads

