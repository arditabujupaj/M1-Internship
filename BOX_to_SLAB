def chain_coms(R_np):
    """Mass-weighted COM of each chain, unwrapped along all dims."""
    Lx, Ly, Lz = box_np
    R_ch = R_np.reshape(N_chains, N_bead, 3)
    coms = np.empty((N_chains, 3))
    for c in range(N_chains):
        pos = R_ch[c].copy()
        # unwrap all dims
        for dim, L in enumerate([Lx, Ly, Lz]):
            for r in range(1, N_bead):
                d = pos[r, dim] - pos[r-1, dim]
                pos[r, dim] -= L * np.round(d / L)
        com = (mass_s[:, None] * pos).sum(0) / mass_s.sum()
        # wrap COM back into box
        for dim, L in enumerate([Lx, Ly, Lz]):
            com[dim] = (com[dim] + L/2) % L - L/2
        coms[c] = com
    return coms

def detect_slab(coms):

    Lx, Ly, Lz = box_np
    dxy = coms[:, None, :2] - coms[None, :, :2]
    dxy[:,:,0] -= Lx * np.round(dxy[:,:,0] / Lx)
    dxy[:,:,1] -= Ly * np.round(dxy[:,:,1] / Ly)
    dist = np.sqrt((dxy**2).sum(-1))

    adj = (dist < COM_CLUSTER_CUTOFF).astype(np.float32)
    np.fill_diagonal(adj, 0)
    _, labels = connected_components(csr_matrix(adj), directed=False,
                                     return_labels=True)
    sizes  = np.bincount(labels)
    best   = int(np.argmax(sizes))

    if sizes[best] <= 1:   # fall back to 3D
        d3 = coms[:, None, :] - coms[None, :, :]
        d3 -= np.array([Lx,Ly,Lz])[None,None,:] * np.round(
              d3 / np.array([Lx,Ly,Lz])[None,None,:])
        dist3 = np.sqrt((d3**2).sum(-1))
        adj3  = (dist3 < COM_CLUSTER_CUTOFF).astype(np.float32)
        np.fill_diagonal(adj3, 0)
        _, labels = connected_components(csr_matrix(adj3), directed=False,
                                         return_labels=True)
        sizes = np.bincount(labels)
        best  = int(np.argmax(sizes))

    return labels == best, int(sizes[best])

def density_profile(R_np):

    Lx, Ly, Lz = box_np
    coms = chain_coms(R_np)
    mask, n_slab = detect_slab(coms)

    # Re-centre: shift everything so slab COM sits at z=0
    if n_slab > 0:
        slab_z = coms[mask, 2]
        slab_z = slab_z - Lz * np.round(slab_z / Lz)
        shift  = float(slab_z.mean())
    else:
        shift = 0.0

    z = (R_np[:, 2] - shift + Lz/2) % Lz - Lz/2
    edges = np.linspace(-Lz/2, Lz/2, PROFILE_BINS + 1)
    cnt, _ = np.histogram(z, bins=edges)
    vol    = Lx * Ly * (Lz / PROFILE_BINS)
    return 0.5*(edges[:-1]+edges[1:]), cnt/vol, n_slab

def coexistence(zc, dens):

    half   = float(zc[-1])
    z_d    = half * 0.15
    z_dl   = half * 0.75
    dm     = np.abs(zc) < z_d
    dil    = np.abs(zc) > z_dl
    rho_d  = float(dens[dm].mean())  if dm.any()  else float('nan')
    rho_dl = float(dens[dil].mean()) if dil.any() else float('nan')
    # beads/nm³ → chains/nm³ → mg/mL
    c_d    = (rho_d  / N_bead) * MW_chain / 602.214076*1000
    c_dl   = (rho_dl / N_bead) * MW_chain / 602.214076*1000
    return rho_d, rho_dl, c_d, c_dl


