# SECTION 8 ENERGY and FORCE FUNCTIONS

@jit
def pbc_diff(ri, rj, box):
    d = ri - rj
    return d - box * jnp.round(d / box)

@jit
def wrap(R, box):
    return (R + box/2) % box - box/2

@jit
def bond_energy(R, box):
    dr = vmap(pbc_diff, in_axes=(0,0,None))(R[bond_i], R[bond_j], box)
    r  = jnp.linalg.norm(dr, axis=1)
    return jnp.sum(0.5 * K_BOND * (r - R0_BOND)**2)

@jit
def nonbonded_energy(R, box):
    dr    = vmap(pbc_diff, in_axes=(0,0,None))(R[pair_i], R[pair_j], box)
    r     = jnp.linalg.norm(dr, axis=1)
    sr    = sig_ij / jnp.maximum(r, 1e-8)
    lj    = 4.0 * LJ_EPS * (sr**12 - sr**6)
    r_min = 2.0**(1.0/6.0) * sig_ij
    e_in  = lj + (1.0 - lam_ij) * LJ_EPS
    e_out = lam_ij * lj
    e_ah  = jnp.where(r < r_min, e_in, e_out)
    e_ah  = jnp.where(r < R_CUT_LJ, e_ah, 0.0)
    rs    = jnp.maximum(r, 0.2)
    e_yuk = (q_i * q_j * YUKAWA_PRE / rs) * jnp.exp(-YUKAWA_KAPPA * rs)
    e_yuk = jnp.where(r < R_CUT_YUK, e_yuk, 0.0)
    return jnp.sum(e_ah) + jnp.sum(e_yuk)

@jit
def total_energy(R, box):
    return bond_energy(R, box) + nonbonded_energy(R, box)

forces_fn = jit(lambda R, box: -grad(total_energy)(R, box))

# SECTION 9  BAOAB LANGEVIN INTEGRATOR

@jit
def baoab_step(R, V, F, key, box, kT):
    c1 = jnp.exp(-gamma_2d * DT)
    c2 = jnp.sqrt((1.0 - c1**2) * kT / mass_2d)
    V  = V + 0.5 * DT * F / mass_2d
    R  = wrap(R + 0.5 * DT * V, box)
    key, sk = random.split(key)
    V  = c1 * V + c2 * random.normal(sk, V.shape)
    R  = wrap(R + 0.5 * DT * V, box)
    F  = forces_fn(R, box)
    V  = V + 0.5 * DT * F / mass_2d
    return R, V, F, key

def make_scan_body(box, kT):
    @jit
    def body(carry, _):
        R, V, F, key = carry
        R, V, F, key = baoab_step(R, V, F, key, box, kT)
        return (R, V, F, key), None
    return body

def init_velocities(key, kT):
    return random.normal(key, (N_total, 3)) * jnp.sqrt(kT / mass_2d)


