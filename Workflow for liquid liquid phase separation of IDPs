# Follows Dignon 2018 paper in which Regy et al 2021 is based.Procedure:
#   1. Find largest cluster (COM distance < 5nm cutoff applied here by me)
#   2. Galilean shift: move slab COM to z=0 each frame
#   3. Histogram ALL beads into bins along z



# Paper cutoffs 
Z_DENSE_CUT  = 5.0    # nm
Z_DILUTE_CUT = 5.0   # nm

# ── Density conversion ──────────────────────────────────────
# Paper formula :
#   c [mg/mL] = rho_beads [beads/nm³] × MW_per_residue / 602.214*1000
#   where MW_per_residue = MW_chain / N_res_aa
#
# CG model correction: 1 CG bead = CG_STRIDE residues
#   rho_residues = rho_CG_beads × CG_STRIDE
#   c [mg/mL] = rho_CG_beads × CG_STRIDE × MW_per_residue / 602.214*1000
#             = rho_CG_beads × CG_STRIDE × MW_chain / N_res_aa / 602.214*1000
#


BEADS_TO_MGML = CG_STRIDE * MW_chain / N_res_aa / 602.214076*1000
# = 10 × 17149.8 / 163 / 602.214*1000 [mg/mL per bead/nm³] Is the conversion of nm-3 to ml

def chain_coms(R_np):
    """Mass-weighted COM of each chain, unwrapped then wrapped into box."""
    Lx, Ly, Lz = box_np
    R_ch = R_np.reshape(N_chains, N_bead, 3)
    coms = np.empty((N_chains, 3))
    for c in range(N_chains):
        pos = R_ch[c].copy()
        for dim, L in enumerate([Lx, Ly, Lz]):
            for r in range(1, N_bead):
                d = pos[r, dim] - pos[r-1, dim]
                pos[r, dim] -= L * np.round(d / L)
        com = (mass_s[:, None] * pos).sum(0) / mass_s.sum()
        for dim, L in enumerate([Lx, Ly, Lz]):
            com[dim] = (com[dim] + L/2) % L - L/2
        coms[c] = com
    return coms

def detect_slab(coms):
    """
    Largest cluster by 3D COM distance with PBC.
    Paper: 'chains with COM distances < 5nm are in the same cluster'
    """
    Lx, Ly, Lz = box_np
    d3  = coms[:, None, :] - coms[None, :, :]
    d3 -= np.array([Lx,Ly,Lz])[None,None,:] * np.round(
          d3 / np.array([Lx,Ly,Lz])[None,None,:])
    dist = np.sqrt((d3**2).sum(-1))
    adj  = (dist < COM_CLUSTER_CUTOFF).astype(np.float32)
    np.fill_diagonal(adj, 0)
    _, labels = connected_components(csr_matrix(adj), directed=False,
                                     return_labels=True)
    sizes = np.bincount(labels)
    best  = int(np.argmax(sizes))
    return labels == best, int(sizes[best])

def density_profile(R_np):
    """
    Z-density profile following Dignon 2018 exactly:
      Step 1: find slab (largest cluster)
      Step 2: Galilean shift  translate ALL particles so slab COM = z=0
      Step 3: histogram ALL beads along z
      Step 4: dens[bin] = count / (Lx * Ly * bin_width)   [beads/nm³]

    The density is per unit volume of each bin, NOT per total box volume.
    This is why the dense phase can reach high mg/mL even with 100 chains:
    all chains pack into a thin slab, giving high local bead density.
    """
    Lx, Ly, Lz = box_np
    coms = chain_coms(R_np)
    mask, n_slab = detect_slab(coms)

    # Galilean shift: move slab COM to z=0
    if n_slab > 0:
        slab_z = coms[mask, 2].copy()
        slab_z -= Lz * np.round(slab_z / Lz)
        shift  = float(slab_z.mean())
    else:
        shift = 0.0

    # Shift ALL particles, re-wrap
    z_all  = (R_np[:, 2] - shift + Lz/2) % Lz - Lz/2
    edges  = np.linspace(-Lz/2, Lz/2, PROFILE_BINS + 1)
    cnt, _ = np.histogram(z_all, bins=edges)

    # Bead count density per bin [beads/nm³]
    bin_vol  = Lx * Ly * (Lz / PROFILE_BINS)   # nm³ per bin
    dens     = cnt / bin_vol                     # beads/nm³
    # beads_to_mgml() applies CG correction: × CG_STRIDE × MW_chain/N_res/602.214

    zc = 0.5 * (edges[:-1] + edges[1:])
    return zc, dens, n_slab

def beads_to_mgml(rho_beads):
    """
    beads/nm³ → mg/mL  matching Dignon 2018 paper exactly.

    Paper (AA): c = rho_residues × MW_chain/N_res / 602.214
    CG model:   rho_residues = rho_CG_beads × CG_STRIDE
    Therefore:  c = rho_CG_beads × CG_STRIDE × MW_chain/N_res / 602.214*1000
                  = rho_CG_beads × BEADS_TO_MGML

    Gives identical mg/mL as AA model for same physical state.
    """
    return rho_beads * BEADS_TO_MGML

def coexistence(zc, dens):
    dm  = np.abs(zc) < Z_DENSE_CUT
    dil = np.abs(zc) > Z_DILUTE_CUT
    rho_d  = float(dens[dm].mean())  if dm.any()  else float('nan')
    rho_dl = float(dens[dil].mean()) if dil.any() else float('nan')
    return rho_d, rho_dl, beads_to_mgml(rho_d), beads_to_mgml(rho_dl)



