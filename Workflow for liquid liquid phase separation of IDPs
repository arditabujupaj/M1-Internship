def build_pair_list(label=""):
    global pair_i, pair_j, sig_ij, lam_ij, q_i, q_j
    t0 = time.time()
    ii_all, jj_all = np.triu_indices(N_total, k=1)
    ch_i = ii_all // N_bead;  ch_j = jj_all // N_bead
    ri   = ii_all %  N_bead;  rj   = jj_all %  N_bead
    bonded = (ch_i == ch_j) & (np.abs(ri.astype(int) - rj.astype(int)) < 2)
    keep   = ~bonded
    sig_np = np.array(sigma_arr)
    lam_np = np.array(lambda_arr)
    pair_i = jnp.array(ii_all[keep], dtype=jnp.int32)
    pair_j = jnp.array(jj_all[keep], dtype=jnp.int32)
    sig_ij = jnp.array(0.5*(sig_np[ii_all[keep]] + sig_np[jj_all[keep]]))
    lam_ij = jnp.array(np.clip(
        MU * 0.5*(lam_np[ii_all[keep]] + lam_np[jj_all[keep]]) + DELTA)) #Here  λij = μ*λ0(ij) − ∆ 
    q_i    = charge_arr[pair_i]
    q_j    = charge_arr[pair_j]
    print(f"  Pair list {label}: {len(pair_i):,} pairs  ({time.time()-t0:.1f}s)")

