    loss_fn      = make_diff_rollout(R_sg, V_sg, xi_sg, vxi_sg)
    val_and_grad = jax.jit(jax.value_and_grad(loss_fn, has_aux=True))

    (loss_val, rg_roll_val), grads_raw = val_and_grad(params)

    loss_now  = float(loss_val)
    rg_roll   = float(rg_roll_val)
    g_mu      = float(grads_raw["mu"])
    g_delta   = float(grads_raw["delta"])

    grads_clipped      = clip_grads(grads_raw)
    updates, opt_state = optimizer.update(grads_clipped, opt_state, params)
    params             = optax.apply_updates(params, updates)
    params             = clip_params_hard(params)

    # ── Tracking ─────────────────────────────────────────────────────────────
    note = ""
    if loss_now < best_loss:
        best_loss  = loss_now
        best_mu    = mu_now
        best_delta = delta_now
        note       = "← BEST"

    history.append((outer, mu_now, delta_now, rg_md, rg_roll, loss_now))

    print(f"{outer:>5} | {rg_md:>7.4f} | {rg_roll:>7.4f} | "
          f"{loss_now:>9.5f} | {mu_now:>8.4f} | {delta_now:>8.4f} | "
          f"{g_mu:>+8.4f} | {g_delta:>+8.4f} | {note}")

    # ── Checkpoint ──────────
    if (outer + 1) % SAVE_EVERY == 0:
        ck = f"opt_ckpt_{outer+1:04d}"
        save_state_flat(R_live, V_live, xi_live, vxi_live, ck, mu_now, delta_now,
                        extra={"outer_step":  np.int64(outer),
                               "loss":        np.float64(loss_now),
                               "rg_md":       np.float64(rg_md),
                               "rg_rollout":  np.float64(rg_roll)})
        np.save("opt_history.npy", np.array(history))

    # ── Convergence ───────────────────────────────────────────────────────────
    if abs(rg_md - TARGET_RG) < CONVERGE_TOL:
        print(f" Converged! Rg_MD = {rg_md:.4f} nm  "
              f"(target {TARGET_RG} ± {CONVERGE_TOL} nm)  at iter {outer}")
        break


# 14. FINAL SUMMARY + CHECKPOINT

print("\n" + "=" * 70)
print(f"  Best μ    = {best_mu:.6f}")
print(f"  Best Δ    = {best_delta:.6f}")
print(f"  Best loss = {best_loss:.6f}")
print("=" * 70)

hist_arr = np.array(history)
np.save("opt_history.npy", hist_arr)


print(f"\nCool-down run with best params (μ={best_mu:.4f}, Δ={best_delta:.4f}) ...")
key, subkey = random.split(key)
R_final, V_final, xi_final, vxi_final = run_md_nondiff(
    R_live, V_live, xi_live, vxi_live,
    best_mu, best_delta, n_steps=50_000
)
save_state_flat(R_final, V_final, xi_final, vxi_final,
                "opt_final", best_mu, best_delta,
