#Here parameters are clipped to stay at a specified range 
def clip_params_hard(p):
    return {
        "mu":    jnp.clip(p["mu"],    MU_LO, MU_HI),
        "delta": jnp.clip(p["delta"], DELTA_LO, DELTA_HI),
    }


def clip_grads(grads, max_norm=GRAD_CLIP):
    leaves = jax.tree_util.tree_leaves(grads)
    g_norm = jnp.sqrt(sum(jnp.sum(g ** 2) for g in leaves))
    factor = jnp.minimum(1.0, max_norm / (g_norm + 1e-8))
    return jax.tree_util.tree_map(lambda g: g * factor, grads)



