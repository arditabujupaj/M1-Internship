# 4.  ENERGY FUNCTION  (differentiable w.r.t. R, mu, delta)

@jax.jit
def yukawa_energy(R):
    ri, rj  = R[idx_i], R[idx_j]
    dr      = jax.vmap(displacement_fn)(ri, rj)
    r       = jnp.linalg.norm(dr, axis=1)
    qi, qj  = charge_arr[idx_i], charge_arr[idx_j]
    r_safe  = jnp.maximum(r, 0.2)
    e_pair  = (qi * qj * YUKAWA_PRE / r_safe) * jnp.exp(-YUKAWA_KAPPA * r_safe)
    e_pair  = jnp.where(r < R_CUT_YUK, e_pair, 0.0)
    return jnp.sum(e_pair)


def total_energy(R, mu, delta):
    """Full HPS-Urry energy; differentiable w.r.t. R, mu, and delta."""
    bond_e  = bond_energy_fn(R)

    ri, rj  = R[idx_i], R[idx_j]
    dr      = jax.vmap(displacement_fn)(ri, rj)
    r       = jnp.linalg.norm(dr, axis=1)
    sig     = 0.5 * (sigma_arr[idx_i] + sigma_arr[idx_j])
    lam     = jnp.clip(
                  mu * 0.5 * (lambda_arr[idx_i] + lambda_arr[idx_j]) - delta,
                  0.0, 1.0)
    sr      = sig / jnp.maximum(r, 1e-6)
    lj      = 4.0 * LJ_EPS * (sr**12 - sr**6)
    r_min   = 2.0 ** (1.0 / 6.0) * sig
    e_inner = lj + (1.0 - lam) * LJ_EPS
    e_outer = lam * lj
    e_pair  = jnp.where(r <= r_min, e_inner, e_outer)
    e_pair  = jnp.where(r < R_CUT_LJ, e_pair, 0.0)
    lj_e    = jnp.sum(e_pair)

    return bond_e + lj_e + yukawa_energy(R)



# 5.  DIFFERENTIABLE NVT NOSE-HOOVER STEP

# the integrator is written explicitly so JAX can differentiate through it.
# State tuple:  (R, V, xi, vxi)
#   R   – positions          (N, 3)
#   V   – velocities         (N, 3)
#   xi  – thermostat coords  (chain_length,)
#   vxi – thermostat momenta (chain_length,)
#
# NHC masses  Q_k = kT * tau^2  (standard choice)

NHC_Q = KT * TAU ** 2 * jnp.ones(CHAIN_LENGTH)   # (chain_length,)


def _nhc_half_step(vxi, xi, ke2, dt_half):
    """
    One half-step of the Nosé-Hoover chain thermostat.
    ke2   – 2 × kinetic energy (scalar)
    Returns updated (vxi, xi).
    """
    # Work from the outermost chain variable inward.
    # G_k = (Q_{k-1} * vxi_{k-1}^2 - kT) / Q_k   for k > 0
    # G_0 = (ke2 - 3*N*kT) / Q_0
    dof = 3.0 * N

    def _chain_step(carry, k):
        vxi_local = carry
        # Force on thermostat k
        G = jnp.where(
            k == 0,
            (ke2 - dof * KT) / NHC_Q[0],
            (NHC_Q[k - 1] * vxi_local[k - 1] ** 2 - KT) / NHC_Q[k],
        )
        # Update vxi[k] (Trotter / Yoshida factor = 1 here for simplicity)
        vxi_new = vxi_local.at[k].set(
            vxi_local[k] + dt_half * G
        )
        return vxi_new, None

    # Forward sweep (outermost → innermost is conventional; we do 0 → L-1)
    vxi_out, _ = lax.scan(_chain_step, vxi, jnp.arange(CHAIN_LENGTH))

    # Update thermostat positions
    xi_out = xi + dt_half * vxi_out

    return vxi_out, xi_out


def nhc_step(R, V, xi, vxi, mu, delta):
    """
    One full NVT NHC velocity-Verlet step.
    Returns updated (R, V, xi, vxi).
    """
    dt      = DT
    dt_half = 0.5 * dt
    mass_3d = mass_arr[:, None]          # (N,1) for broadcasting

    # ── 1. NHC half-kick (thermostat acts on velocities) ────────────────────
    ke2        = jnp.sum(mass_arr * jnp.sum(V ** 2, axis=1))
    scale      = jnp.exp(-dt_half * vxi[0])
    V_scaled   = V * scale
    ke2_scaled = ke2 * scale ** 2
    vxi1, xi1  = _nhc_half_step(vxi, xi, ke2_scaled, dt_half)

    # ── 2. Velocity half-kick from forces ───────────────────────────────────
    F          = -jax.grad(total_energy, argnums=0)(R, mu, delta)   # (N,3)
    V_half     = V_scaled + dt_half * F / mass_3d

    # ── 3. Position full step ────────────────────────────────────────────────
    R_new      = R + dt * V_half

    # ── 4. Force at new positions + velocity full-kick ───────────────────────
    F_new      = -jax.grad(total_energy, argnums=0)(R_new, mu, delta)
    V_new      = V_half + dt_half * F_new / mass_3d

    # ── 5. NHC second half-kick ──────────────────────────────────────────────
    ke2_new    = jnp.sum(mass_arr * jnp.sum(V_new ** 2, axis=1))
    vxi2, xi2  = _nhc_half_step(vxi1, xi1, ke2_new, dt_half)
    scale2     = jnp.exp(-dt_half * vxi2[0])
    V_final    = V_new * scale2

    return R_new, V_final, xi2, vxi2



# 6.  HELPERS

def compute_rg(R):
    com = jnp.mean(R, axis=0)
    return jnp.sqrt(jnp.mean(jnp.sum((R - com) ** 2, axis=1)))


def compute_temperature(V):
    ke = 0.5 * jnp.sum(mass_arr[:, None] * V ** 2)
    return (2.0 * ke) / (3.0 * N * 0.008314)


def init_velocities(key, T=TEMPERATURE):
    """Maxwell-Boltzmann initialisation."""
    kT_local = T * 0.008314
    std      = jnp.sqrt(kT_local / mass_arr[:, None])
    V0       = random.normal(key, (N, 3)) * std
    V0       = V0 - jnp.mean(V0, axis=0)    # zero COM momentum
    return V0



# 7.  SAVE / LOAD  (stores the flat (R, V, xi, vxi) tuple)

def save_state_flat(R, V, xi, vxi, prefix, mu, delta, extra=None):
    save_dict = dict(
        position       = np.array(R),
        velocity       = np.array(V),
        chain_position = np.array(xi),
        chain_momentum = np.array(vxi),
        mu             = np.float64(mu),
        delta          = np.float64(delta),
    )
    if extra:
        save_dict.update(extra)
    np.savez(f"{prefix}_state.npz", **save_dict)
    np.save(f"{prefix}_positions.npy", np.array(R))
    rg = float(compute_rg(jnp.array(R)))
    print(f"{prefix}_state.npz  (Rg={rg:.4f} nm, μ={mu:.4f}, Δ={delta:.4f})")


def load_state_flat(prefix, key=random.PRNGKey(0)):
    """
    Load (R, V, xi, vxi) from a flat _state.npz.

    npz_path = f"{prefix}_state.npz"
    if not os.path.exists(npz_path):
        raise FileNotFoundError(
            f"Cannot find '{npz_path}'.\n"
            f"Make sure the file is in the same directory as this script,\n"
            f"or set CHECKPOINT_PREFIX to the correct path prefix."
        )

    d   = np.load(npz_path, allow_pickle=True)
    R   = jnp.array(d["position"],  dtype=jnp.float64)   # (N, 3)
    mu  = float(d["mu"])    if "mu"    in d else MU_INIT
    delta = float(d["delta"]) if "delta" in d else DELTA_INIT

    # ── Velocity ──────────────────────────────────────────────────────────────
    if "velocity" in d:
        V = jnp.array(d["velocity"], dtype=jnp.float64)
    elif "momentum" in d:
        # old format stored momentum = mass * velocity
        mom = jnp.array(d["momentum"], dtype=jnp.float64)
        V   = mom / mass_arr[:, None]
    else:
        print(" No velocity/momentum found re-starting from Maxwell-Boltzmann.")
        V   = init_velocities(key)

    # Thermostat chain
    if "chain_position" in d and d["chain_position"].shape == (CHAIN_LENGTH,):
        # New flat format
        xi  = jnp.array(d["chain_position"], dtype=jnp.float64)
        vxi = jnp.array(d["chain_momentum"], dtype=jnp.float64)
    else:
        # Old format: chain was (chain_length, 2?) or nested; just zero it out
        print(" NHC chain format mismatch — zeroing thermostat state.")
        xi  = jnp.zeros(CHAIN_LENGTH, dtype=jnp.float64)
        vxi = jnp.zeros(CHAIN_LENGTH, dtype=jnp.float64)

    rg = float(compute_rg(R))
    print(f"Loaded '{npz_path}'  Rg={rg:.4f} nm  μ={mu:.4f}  Δ={delta:.4f}")
    return R, V, xi, vxi, mu, delta
# 8.  NON-DIFFERENTIABLE PRODUCTION RUN  (warm-up / burn-in)

# This is a plain lax.scan using our explicit NHC step.  jax.grad is NOT
# called on this; it just advances the trajectory.

def run_md_nondiff(R, V, xi, vxi, mu, delta, n_steps, key=None):
    """Run n_steps of NHC-NVT MD without differentiating."""

    def step(carry, _):
        R_c, V_c, xi_c, vxi_c = carry
        R_n, V_n, xi_n, vxi_n = nhc_step(R_c, V_c, xi_c, vxi_c, mu, delta)
        return (R_n, V_n, xi_n, vxi_n), None

    (R_f, V_f, xi_f, vxi_f), _ = lax.scan(
        step, (R, V, xi, vxi), None, length=n_steps
    )
    return R_f, V_f, xi_f, vxi_f



# 9.  DIFFERENTIABLE MD ROLLOUT  (backprop flows through this)
# GRAD_INNER   – number of NHC steps to differentiate through.
#                ↑ more = better gradient, more memory.
# SNAPSHOT_EVERY – collect Rg every k steps.  The loss is mean(Rg) over
#                  snapshots, which gives a smoother, lower-variance gradient
#                  than using only the final frame.
# USE_CHECKPOINT – jax.checkpoint on the inner step to save memory.

GRAD_INNER     = 10000        # steps to backprop through  (tune to your GPU RAM)
SNAPSHOT_EVERY = 50         # collect Rg every k steps   → GRAD_INNER/k snapshots
USE_CHECKPOINT = True       # recommended for GRAD_INNER > 200

assert GRAD_INNER % SNAPSHOT_EVERY == 0, \
    "GRAD_INNER must be divisible by SNAPSHOT_EVERY"
N_SNAPSHOTS = GRAD_INNER // SNAPSHOT_EVERY


def make_diff_rollout(R_start, V_start, xi_start, vxi_start):
    """
    Returns a loss function that:
      - Takes (mu, delta) as parameters.
      - Runs GRAD_INNER real NHC-NVT steps starting from the given state.
      - Collects positions every SNAPSHOT_EVERY steps.
      - Returns  (loss, mean_Rg)  where  loss = (mean_Rg − TARGET_RG)².

    Gradients w.r.t. mu and delta backpropagate through the entire MD scan.
    """

    def loss_fn(params):
        mu    = params["mu"]
        delta = params["delta"]

        # Inner step: one NHC step, accumulate Rg at every SNAPSHOT_EVERY-th step
        def micro_scan(carry, _):
            """Runs SNAPSHOT_EVERY steps and returns the position at the end."""
            R_c, V_c, xi_c, vxi_c = carry

            def single_step(c, __):
                R_s, V_s, xi_s, vxi_s = c
                R_n, V_n, xi_n, vxi_n = nhc_step(R_s, V_s, xi_s, vxi_s, mu, delta)
                return (R_n, V_n, xi_n, vxi_n), None

            step_fn = jax.checkpoint(single_step) if USE_CHECKPOINT else single_step
            (R_f, V_f, xi_f, vxi_f), _ = lax.scan(
                step_fn, (R_c, V_c, xi_c, vxi_c),
                None, length=SNAPSHOT_EVERY
            )
            rg_snap = compute_rg(R_f)
            return (R_f, V_f, xi_f, vxi_f), rg_snap

        # Outer scan collects one Rg per SNAPSHOT_EVERY block
        _, rg_trace = lax.scan(
            micro_scan,
            (R_start, V_start, xi_start, vxi_start),
            None,
            length=N_SNAPSHOTS,
        )

        mean_rg = jnp.mean(rg_trace)
        loss    = (mean_rg - TARGET_RG) ** 2
        return loss, mean_rg

    return loss_fn
